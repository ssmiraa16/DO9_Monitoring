{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        }
      },
      "gridPos": {"h": 3, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "title": "Количество нод",
      "type": "stat",
      "targets": [
        {"expr": "count(up{job=\"node_exporter\"} == 1)", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        }
      },
      "gridPos": {"h": 3, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "title": "Количество контейнеров",
      "type": "stat",
      "targets": [
        {"expr": "count(container_last_seen)", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        }
      },
      "gridPos": {"h": 3, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "title": "Количество стеков",
      "type": "stat",
      "targets": [
        {"expr": "count(count by (container_label_com_docker_stack_namespace) (container_last_seen{container_label_com_docker_stack_namespace!=\"\"}))", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        }
      },
      "gridPos": {"h": 3, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "title": "Количество CPU",
      "type": "stat",
      "targets": [
        {"expr": "count(node_cpu_seconds_total{mode=\"idle\"})", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0, "max": 100}
      },
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 3},
      "id": 5,
      "title": "Использование CPU по сервисам",
      "type": "timeseries",
      "targets": [
        {"expr": "rate(container_cpu_usage_seconds_total[5m]) * 100", "legendFormat": "{{name}}", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0, "max": 100}
      },
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 3},
      "id": 6,
      "title": "Использование CPU по ядрам и узлам",
      "type": "timeseries",
      "targets": [
        {"expr": "100 - (avg by (instance, cpu) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{instance}} - {{cpu}}", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 13},
      "id": 7,
      "title": "Затраченная RAM",
      "type": "timeseries",
      "targets": [
        {"expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "{{instance}}", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 13},
      "id": 8,
      "title": "Доступная память",
      "type": "timeseries",
      "targets": [
        {"expr": "node_memory_MemAvailable_bytes", "legendFormat": "{{instance}}", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 13},
      "id": 9,
      "title": "Занятая память",
      "type": "timeseries",
      "targets": [
        {"expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "{{instance}}", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {"text": " DOWN", "color": "red"},
                "1": {"text": " UP", "color": "green"}
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 0}
            ]
          }
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 21},
      "id": 10,
      "title": "Доступность google.com",
      "type": "stat",
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        }
      },
      "targets": [
        {"expr": "probe_success{instance=\"google.com\"}"}
      ]
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 21},
      "id": 11,
      "title": "Отправленные сообщения в RabbitMQ",
      "type": "stat",
      "targets": [
        {"expr": "sum(rate(rabbitmq_published_total[180m]))", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 21},
      "id": 12,
      "title": "Обработанные сообщения в RabbitMQ",
      "type": "stat",
      "targets": [
        {"expr": "sum(rate(rabbitmq_messages_processed_total[120m]))", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 21},
      "id": 13,
      "title": "Количество бронирований",
      "type": "stat",
      "targets": [
        {"expr": "sum(rate(bookings_total[120m]))", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 29},
      "id": 14,
      "title": "Запросы на Gateway",
      "type": "timeseries",
      "targets": [
        {"expr": "sum(rate(http_server_requests_seconds_count{job=\"services\", instance=~\"gateway.*\"}[5m]))", "legendFormat": "gateway requests/s", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 29},
      "id": 15,
      "title": "Запросы на авторизацию",
      "type": "timeseries",
      "targets": [
        {"expr": "rate(auth_requests_received_total[120m])", "legendFormat": "auth requests/s", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "loki"},
      "gridPos": {"h": 15, "w": 24, "x": 0, "y": 37},
      "id": 16,
      "interval": "10s",
      "title": "Логи приложения",
      "type": "logs",
      "maxDataPoints": 100,
      "targets": [
        {
          "expr": "{container=~\".+\"}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["monitoring", "devops"],
  "templating": {
    "list": []
